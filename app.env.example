# Environment variables for the Portainer stack defined in docker-compose.prod.yml.
#
# How to use in Portainer:
#   Stack editor → "Environment variables" panel → "Load variables from .env file"
#   (or paste each KEY=VALUE manually). The compose file references each one as ${KEY}.
#
# NOT for committing real values — fill in a copy stored outside the repo.
# Required vars are validated at boot in app/src/app.config.ts (REQUIRED_ENV_VARS).
# Missing any required value → backend refuses to start with a clear error.

# --- Image versions (optional — empty defaults to :latest) ---
APP_TAG=latest
WEB_TAG=latest

# --- Core ---
JWT_SECRET=change-me-long-random
ENCRYPTION_KEY=change-me-32-bytes-hex
BCRYPT_COST=10

# --- Power BI / Azure AD ---
POWER_BI_BASE_URL=https://api.powerbi.com/v1.0/myorg
AZURE_URL=https://login.microsoftonline.com/common/oauth2/token
AZURE_CLIENT_SECRET=
AZURE_GRANT_TYPE=password
AZURE_GRANT_TYPE2=refresh_token
AZURE_SCOPE=openid
AZURE_RESOURCE=https://analysis.windows.net/powerbi/api

# --- SMTP (welcome / reset / notifications) ---
MAIL_SMTP=smtp.condor.com.br
MAIL_PORT=587
APP_MAIL_USER=
APP_MAIL_PASS=
# Condor's Postfix only speaks TLS 1.0 — keep this unless that changes.
MAIL_MIN_TLS=TLSv1

# --- App URLs ---
BASE_URL=https://bi.condor.com.br
USER_LIMIT=100
MULTER_TYPES=image/png,image/jpeg,image/svg+xml

# --- Bull Board basic-auth (/admin/queues) ---
BULL_BOARD_USER=
BULL_BOARD_PASS=
