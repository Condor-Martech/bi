# ==============================================
#  power-bi — Variáveis de ambiente
#  Copie este arquivo para .env e preencha os valores.
#  As variáveis marcadas (obrigatória) são validadas no boot;
#  se faltar alguma, a aplicação não inicia.
# ==============================================

# --- Banco de dados (MongoDB) ---
# (obrigatória) Conexão usada pela aplicação e pelo serviço de backup (mongodump/mongorestore).
MONGO_DSN=mongodb://user:pass@host:port/app?authSource=admin

# --- Autenticação ---
# (obrigatória) Segredo para assinar/verificar os JWT.
JWT_SECRET=
# Tempo de expiração do token (ex: 8h, 20h, 24h, 30d). Padrão: 20h
JWT_EXPIRES_IN=20h
# (obrigatória) Chave usada pelo EncryptionService.
ENCRYPTION_KEY=
# Custo do hash bcrypt (número de rounds).
BCRYPT_COST=10

# --- Power BI / Azure AD ---
# (obrigatória) Base URL da API do Power BI.
POWER_BI_BASE_URL=https://api.powerbi.com/v1.0/myorg
# (obrigatória) Endpoint de token do Azure AD.
AZURE_URL=
# (obrigatória) Client secret do app registrado no Azure AD.
AZURE_CLIENT_SECRET=
AZURE_GRANT_TYPE=password
AZURE_GRANT_TYPE2=refresh_token
AZURE_SCOPE=
AZURE_RESOURCE=

# --- Redis (cache + filas Bull) ---
# (obrigatória)
REDIS_HOST=localhost
REDIS_PORT=6379

# --- E-mail (SMTP) ---
MAIL_SMTP=
MAIL_PORT=587
APP_MAIL_USER=
APP_MAIL_PASS=
# Workaround para SMTPs legacy que solo hablan TLS 1.0 (ej: Postfix viejo).
# Default seguro = TLSv1.2 sin override de ciphers. Solo bajar si el server lo exige.
# ⚠️ TLS 1.0 está deprecated (RFC 8996). Usar solo si IT no puede actualizar el SMTP.
MAIL_MIN_TLS=TLSv1.2
MAIL_CIPHERS=

# --- Sentry (monitoramento de erros) ---
SENTRY_DSN=

# --- Outros ---
BASE_URL=
USER_LIMIT=
MULTER_TYPES=
